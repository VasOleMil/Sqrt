 RowBox[{
  RowBox[{"SqrtRowMC", "=", 
   RowBox[{"Compile", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"S", ",", "_Real"}], "}"}], "}"}], ",", 
