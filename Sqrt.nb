       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"S", "<=", "0.0"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.0", ",", "0.0"}], "}"}], ",", 
         RowBox[{
          RowBox[{"b", "=", "2.0"}], ";", 
          RowBox[{"d", "=", "2"}], ";", 
          RowBox[{"e", "=", 
           RowBox[{
            RowBox[{"Floor", "[", 
             RowBox[{"Log2", "[", "S", "]"}], "]"}], "+", "1"}]}], ";", "\n", 
          "\t   ", 
          RowBox[{"d", "+=", 
           RowBox[{"Mod", "[", 
            RowBox[{"e", ",", "2"}], "]"}]}], ";", " ", 
          RowBox[{"X", "=", 
           RowBox[{"S", "/", 
            RowBox[{"(", 
             RowBox[{"b", "^", "e"}], ")"}]}]}], ";", 
          RowBox[{"X", "*=", 
           RowBox[{"b", "^", "d"}]}], ";", " ", "\[IndentingNewLine]", 
          RowBox[{"c", "=", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"X", ">=", "1.0"}], ",", "1.0", ",", 
             RowBox[{"-", "1.0"}]}], "]"}]}], ";", 
          RowBox[{"b", "=", 
           RowBox[{"b", "^", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"e", "-", "d"}], ")"}], "/", "2"}], ")"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"n", "=", "1"}], ";", "                           ", 
          RowBox[{"x", "=", "X"}], "  ", ";", 
          RowBox[{"s", "=", 
           RowBox[{
            RowBox[{"x", "*", "x"}], "-", "X"}]}], ";", 
          RowBox[{"s", "=", 
           FractionBox[
            RowBox[{"2.0", " ", "x", " ", "s"}], 
            RowBox[{
             RowBox[{"4.0", " ", "X"}], "+", " ", 
             RowBox[{"3.0", " ", "s"}]}]]}], ";", "\[IndentingNewLine]", 
          RowBox[{"While", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"x", "+", 
              RowBox[{"c", "*", "s"}]}], ">", "x"}], ",", 
            RowBox[{
             RowBox[{"x", "-=", "s"}], ";", 
             RowBox[{"s", "=", 
              RowBox[{
               RowBox[{"x", "*", "x"}], "-", "X"}]}], ";", 
             RowBox[{"s", "=", 
              FractionBox[
               RowBox[{"2.0", " ", "x", " ", "s"}], 
               RowBox[{
                RowBox[{"4.0", " ", "X"}], "+", " ", 
                RowBox[{"3.0", " ", "s"}]}]]}], ";", 
             RowBox[{"n", "++"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"x", "*=", "b"}], ";", 
          RowBox[{"s", "*=", "b"}], ";", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              FractionBox["x", "2.0"], "+", 
              RowBox[{"(", 
               RowBox[{
                FractionBox["x", "4.0"], "+", 
                RowBox[{"(", 
                 RowBox[{
                  FractionBox["x", "4.0"], "-", "s"}], ")"}]}], ")"}]}], 
             ")"}], ",", 
            RowBox[{"N", "[", "n", "]"}]}], "}"}]}]}], "]"}]}], "]"}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
